@* QuestionCard.razor *@
<div class="question-card @(string.IsNullOrEmpty(Question.Answer) ? "unanswered" : "")">
    <div class="card-row">
        @if (string.IsNullOrEmpty(Question.Answer))
        {
            <span class="warn-icon">⚠️</span>
        }
        <span class="q-text">@Question.QuestionText</span>
    </div>
    <div class="card-tags">
        @if (Question.Platform.HasValue)
        {
            <span class="tag tag-platform">@Question.Platform</span>
        }
        <span class="tag tag-type">@GetTypeLabel(Question.FieldType)</span>
    </div>
    <div class="card-body">
        @AnswerInput
    </div>
    @if (ChildContent is not null)
    {
        <div class="card-footer">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public CollectedQuestion Question { get; set; } = default!;
    [Parameter] public RenderFragment? AnswerInput { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static string GetTypeLabel(QuestionFieldType type) => type switch
    {
        QuestionFieldType.Select => "Select",
        QuestionFieldType.Radio => "Radio",
        QuestionFieldType.Checkbox => "Checkbox",
        QuestionFieldType.File => "File",
        _ => "Input"
    };
}
