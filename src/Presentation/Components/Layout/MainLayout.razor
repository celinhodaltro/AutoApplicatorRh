@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar @(_sidebarExpanded ? "expanded" : "collapsed")">
        <div class="sidebar-header">
            @if (_sidebarExpanded)
            {
                <div class="sidebar-brand">
                    <span class="sb-logo">⚡</span>
                    <span class="sb-title">AutoApplicator</span>
                </div>
            }
            else
            {
                <div class="sb-logo-mini">⚡</div>
            }
        </div>

        <nav class="sidebar-nav">
            <a href="/" class="nav-item" title="Dashboard">
                <span class="nav-icon">📊</span>
                @if (_sidebarExpanded) { <span class="nav-label">Dashboard</span> }
            </a>
            <a href="/profiles" class="nav-item" title="Profiles">
                <span class="nav-icon">👤</span>
                @if (_sidebarExpanded) { <span class="nav-label">Profiles</span> }
            </a>
            <a href="/jobs" class="nav-item" title="Jobs">
                <span class="nav-icon">💼</span>
                @if (_sidebarExpanded) { <span class="nav-label">Jobs</span> }
            </a>
            <a href="/questions" class="nav-item" title="Questions">
                <span class="nav-icon">❓</span>
                @if (_sidebarExpanded) { <span class="nav-label">Questions</span> }
            </a>
            <a href="/settings" class="nav-item" title="Settings">
                <span class="nav-icon">⚙️</span>
                @if (_sidebarExpanded) { <span class="nav-label">Settings</span> }
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="status-dot @(AutomationService.IsRunning ? "running" : "idle")"></div>
            @if (_sidebarExpanded)
            {
                <span class="status-text">@(AutomationService.IsRunning ? "Running" : "Idle")</span>
            }
        </div>
    </aside>

    <div class="main-area">
        <TopBar OnToggleSidebar="ToggleSidebar" />

        <main class="content-area">
            @Body
        </main>
    </div>
</div>

<RadzenDialog />
