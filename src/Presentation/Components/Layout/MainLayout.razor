@inherits LayoutComponentBase

<div style="display: flex; height: 100vh; overflow: hidden;">
    <RadzenSidebar Expanded="true" Style="width: 260px; position: fixed; left: 0; top: 0; height: 100vh; z-index: 100; display: flex; flex-direction: column;">
        <div style="padding: 20px 16px; border-bottom: 1px solid var(--rz-sidebar-border);">
            <div style="display: flex; align-items: center; gap: 10px;">
                <span style="font-size: 28px; color: var(--rz-primary);">⚡</span>
                <RadzenText TextStyle="TextStyle.H5" style="margin: 0; font-weight: 700;">AutoApplicator</RadzenText>
            </div>
        </div>

        <div style="padding: 12px 12px 4px;">
            <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary); text-transform: uppercase; letter-spacing: 0.5px; font-size: 11px; padding: 0 8px;">Navigation</RadzenText>
        </div>

        <RadzenPanelMenu Style="flex: 1;">
            <RadzenPanelMenuItem Text="Dashboard" Path="" Icon="dashboard" />
            <RadzenPanelMenuItem Text="Profiles" Path="profiles" Icon="account_circle" />
            <RadzenPanelMenuItem Text="Jobs" Path="jobs" Icon="work" />
            <RadzenPanelMenuItem Text="Questions" Path="questions" Icon="help" />
            <RadzenPanelMenuItem Text="Settings" Path="settings" Icon="settings" />
        </RadzenPanelMenu>

        <div style="padding: 16px; border-top: 1px solid var(--rz-sidebar-border); margin-top: auto;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <span style="width: 8px; height: 8px; border-radius: 50%; background: #4caf50; display: inline-block;"></span>
                <div>
                    <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500;">System Online</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-tertiary);">Ready to process</RadzenText>
                </div>
            </div>
        </div>
    </RadzenSidebar>

    <div style="margin-left: 260px; flex: 1; display: flex; flex-direction: column; min-height: 100vh;">
        <div style="display: flex; align-items: center; justify-content: flex-end; padding: 8px 32px; border-bottom: 1px solid var(--rz-grid-border); background: var(--rz-surface); gap: 16px; min-height: 48px;">
            <RadzenButton Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Base" Click="@StartAutomation">
                <span style="display: flex; align-items: center; gap: 6px;">
                    <span>▶</span>
                    <span>Start Automation</span>
                </span>
            </RadzenButton>
            <RadzenButton Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Base" Click="@StopAutomation">
                <span style="display: flex; align-items: center; gap: 6px;">
                    <span>⏹</span>
                    <span>Stop</span>
                </span>
            </RadzenButton>
        </div>

        <div style="flex: 1; padding: 28px 32px; overflow-y: auto; background: #f5f5f5;">
            @Body
        </div>
    </div>
</div>

<RadzenDialog />

@code {
    private async Task StartAutomation()
    {
        // Placeholder for automation start
    }

    private async Task StopAutomation()
    {
        // Placeholder for automation stop
    }
}
