<div style="border: 1px solid var(--rz-grid-border); border-radius: 8px; padding: 16px; background: var(--rz-surface); margin-bottom: 12px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
            <RadzenText TextStyle="TextStyle.H6">@Job.Title</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary);">@Job.Company</RadzenText>
            <div style="display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap;">
                <RadzenBadge BadgeStyle="BadgeStyle.Light">@Job.Location</RadzenBadge>
                @if (!string.IsNullOrEmpty(Job.Salary))
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Success">@Job.Salary</RadzenBadge>
                }
                <RadzenBadge BadgeStyle="@GetStatusBadge(Job.Status)">@Job.Status</RadzenBadge>
            </div>
        </div>
        @if (Job.MatchScore.HasValue)
        {
            <div style="text-align: center;">
                <RadzenText TextStyle="TextStyle.H4">@Job.MatchScore.Value%</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary);">Match</RadzenText>
            </div>
        }
    </div>
    <div style="margin-top: 8px;">
        <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary);">Posted: @Job.PostedDate.ToShortDateString()</RadzenText>
    </div>
    @if (!string.IsNullOrEmpty(Job.Summary))
    {
        <div style="margin-top: 8px; color: var(--rz-text-secondary); font-size: 0.875rem;">
            @Job.Summary
        </div>
    }
    <div style="display: flex; gap: 8px; margin-top: 12px;">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public JobListing Job { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private BadgeStyle GetStatusBadge(JobStatus status) => status switch
    {
        JobStatus.New => BadgeStyle.Info,
        JobStatus.Reviewed => BadgeStyle.Warning,
        JobStatus.Approved => BadgeStyle.Success,
        JobStatus.Rejected => BadgeStyle.Danger,
        JobStatus.Applied => BadgeStyle.Primary,
        JobStatus.Pending => BadgeStyle.Warning,
        JobStatus.Skipped => BadgeStyle.Light,
        JobStatus.Error => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };
}
