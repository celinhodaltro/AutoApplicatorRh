@using AutoApplicator.Infrastructure.Services
@inject AutomationService AutomationService

<div class="topbar">
    <div class="topbar-left">
        <button class="menu-toggle" @onclick="@(async () => await OnToggleSidebar.InvokeAsync())" title="Toggle sidebar">
            <span class="hamburger">☰</span>
        </button>
        <div class="app-brand">
            <span class="app-logo">⚡</span>
            <span class="app-name">AutoApplicator</span>
        </div>
    </div>

    <div class="topbar-center">
        @if (AutomationService.IsRunning)
        {
            <div class="automation-status">
                <div class="status-spinner"></div>
                <span class="status-text">
                    @AutomationService.CurrentStatus.Progress @AutomationService.CurrentStatus.Message
                </span>
            </div>
        }
        else
        {
            <div class="mode-selector">
                <button class="mode-btn @(_mode == AutomationMode.Search ? "active" : "")" @onclick="() => _mode = AutomationMode.Search" title="Search for jobs only">🔍 Search</button>
                <button class="mode-btn @(_mode == AutomationMode.Apply ? "active" : "")" @onclick="() => _mode = AutomationMode.Apply" title="Apply to approved jobs only">📤 Apply</button>
                <button class="mode-btn @(_mode == AutomationMode.Full ? "active" : "")" @onclick="() => _mode = AutomationMode.Full" title="Search then apply">⚡ Full</button>
            </div>
        }
    </div>

    <div class="topbar-right">
        @if (AutomationService.IsRunning)
        {
            <button class="topbar-btn stop-btn" @onclick="StopAutomation">⏹ Stop</button>
        }
        else
        {
            <button class="topbar-btn start-btn" @onclick="StartAutomation">
                @(_mode switch
                {
                    AutomationMode.Search => "🔍 Search",
                    AutomationMode.Apply => "📤 Apply",
                    AutomationMode.Full => "⚡ Full Auto",
                    _ => "▶ Start"
                })
            </button>
        }
        <NotificationBell />
    </div>
</div>

@code {
    [Parameter] public EventCallback OnToggleSidebar { get; set; }

    private AutomationMode _mode = AutomationMode.Search;
    private bool _subscribed;

    protected override void OnInitialized()
    {
        if (!_subscribed)
        {
            AutomationService.StatusChanged += OnAutomationStatusChanged;
            _subscribed = true;
        }
    }

    private async void OnAutomationStatusChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch { }
    }

    private async Task StartAutomation()
    {
        var globalEasyApply = Preferences.Get("global_easy_apply", false);
        await Task.Run(() => AutomationService.StartAsync(_mode, globalEasyApply));
    }

    private void StopAutomation()
    {
        AutomationService.Stop();
    }

    public void Dispose()
    {
        if (_subscribed)
        {
            AutomationService.StatusChanged -= OnAutomationStatusChanged;
            _subscribed = false;
        }
    }
}
