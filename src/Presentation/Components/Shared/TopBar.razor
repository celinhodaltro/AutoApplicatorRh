@using AutoApplicator.Application.Interfaces
@using Microsoft.Extensions.Logging


<div class="topbar">
    <div class="topbar-left">
        <button class="menu-toggle" @onclick="@(async () => await OnToggleSidebar.InvokeAsync())" title="Toggle sidebar">
            <span class="hamburger">☰</span>
        </button>
        <div class="app-brand">
            <span class="app-logo"><RadzenIcon Icon="flash_on" /></span>
            <span class="app-name">AutoApplicator</span>
        </div>
    </div>

    <div class="topbar-center">
        @if (AutomationService.IsRunning)
        {
            <div class="automation-status">
                <div class="status-spinner"></div>
                <div class="profile-statuses">
                    @foreach (var kvp in AutomationService.ProfileStatuses)
                    {
                        <div class="profile-status-item">
                            <span class="profile-name">@kvp.Key</span>
                            <span class="profile-status">@kvp.Value</span>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="mode-selector">
                <button class="mode-btn @(_mode == AutomationMode.Search ? "active" : "")"
                        @onclick="() => _mode = AutomationMode.Search"
                        title="Search for jobs only">
                    <RadzenIcon Icon="search" /> Search
                </button>
                <button class="mode-btn @(_mode == AutomationMode.Apply ? "active" : "")"
                        @onclick="() => _mode = AutomationMode.Apply"
                        title="Apply to approved jobs only">
                    <RadzenIcon Icon="send" /> Apply
                </button>
                <button class="mode-btn @(_mode == AutomationMode.Full ? "active" : "")"
                        @onclick="() => _mode = AutomationMode.Full"
                        title="Search then apply">
                    <RadzenIcon Icon="flash_on" /> Full
                </button>
            </div>
        }
    </div>

    <div class="topbar-right">
        @if (AutomationService.IsRunning)
        {
            <RadzenButton ButtonStyle="ButtonStyle.Danger" Click="@StopAutomation">
                <RadzenIcon Icon="stop" /> Stop
            </RadzenButton>
        }
        else
        {
            <RadzenButton ButtonStyle="ButtonStyle.Primary" Click="@StartAutomation">
                @switch (_mode)
                {
                    case AutomationMode.Search:
                        <RadzenIcon Icon="search" /> <span>Search</span>
                        break;
                    case AutomationMode.Apply:
                        <RadzenIcon Icon="send" /> <span>Apply</span>
                        break;
                    case AutomationMode.Full:
                        <RadzenIcon Icon="flash_on" /> <span>Full Auto</span>
                        break;
                    default:
                        <RadzenIcon Icon="play_arrow" /> <span>Start</span>
                        break;
                }
            </RadzenButton>
        }
        <NotificationBell />
    </div>
</div>
