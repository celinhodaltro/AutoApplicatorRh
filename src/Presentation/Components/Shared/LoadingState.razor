@* LoadingState.razor *@
<div style="display:flex; justify-content:center; align-items:center; padding:60px 0;">
    <div style="width:36px; height:36px; border:3px solid #e0e0e0; border-top:3px solid #667eea; border-radius:50%; animation: lspin 0.7s linear infinite;"></div>
    <style>
        @@keyframes lspin { to { transform: rotate(360deg); } }
    </style>
</div>
