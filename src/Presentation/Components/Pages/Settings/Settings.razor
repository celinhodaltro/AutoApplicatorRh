@page "/settings"
@using Radzen
@using Radzen.Blazor

<RadzenText TextStyle="TextStyle.H4" style="margin-bottom: 24px;">Settings</RadzenText>

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Accounts">
            <div style="padding: 16px;">
                <RadzenText TextStyle="TextStyle.Body2">Log in to each platform.</RadzenText>
                <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" Click="@(() => OpenLogin(PlatformType.LinkedIn))"><RadzenIcon Icon="vpn_key" /> LinkedIn Login</RadzenButton>
                    <RadzenButton ButtonStyle="ButtonStyle.Info" Click="@(() => OpenLogin(PlatformType.Indeed))"><RadzenIcon Icon="vpn_key" /> Indeed Login</RadzenButton>
                    <RadzenButton ButtonStyle="ButtonStyle.Secondary" Click="@(() => OpenLogin(PlatformType.Gupy))"><RadzenIcon Icon="vpn_key" /> Gupy Login</RadzenButton>
                </div>
            </div>
        </RadzenTabsItem>
        <RadzenTabsItem Text="Automation">
            <div style="padding: 16px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
                    <RadzenSwitch @bind-Value="@_globalEasyApply" />
                    <span>Easy Apply only</span>
                </div>
                <RadzenButton ButtonStyle="ButtonStyle.Primary" Click="@SaveSettings"><RadzenIcon Icon="save" /> Save Settings</RadzenButton>
            </div>
        </RadzenTabsItem>
        <RadzenTabsItem Text="Logs">
            <div style="padding: 16px;">
                <RadzenButton Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Base" Click="@OpenLogsFolder"><RadzenIcon Icon="folder_open" /> Open Folder</RadzenButton>
            </div>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>
