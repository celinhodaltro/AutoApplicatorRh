@page "/jobs/{Id:guid}"
@using Radzen
@using Radzen.Blazor
@using AutoApplicator.Domain.Enums


@if (ViewModel.Job is null)
{
    if (ViewModel.IsLoading)
    {
        <LoadingState />
    }
    else
    {
        <RadzenText TextStyle="TextStyle.Body1">Job not found.</RadzenText>
    }
}
else
{
    var job = ViewModel.Job;

    <RadzenButton class="back-button" Text="← Back to Jobs" ButtonStyle="ButtonStyle.Secondary" Click="@NavigateBackToJobList" />

    <RadzenText TextStyle="TextStyle.H4">@job.Title</RadzenText>
    <RadzenText TextStyle="TextStyle.H6" class="job-company">@job.Company</RadzenText>

    <div class="badges-row">
        <RadzenBadge BadgeStyle="BadgeStyle.Light">@job.Location</RadzenBadge>
        @if (!string.IsNullOrEmpty(job.Salary))
        {
            <RadzenBadge BadgeStyle="BadgeStyle.Success">@job.Salary</RadzenBadge>
        }
        <StatusBadge StatusText="@job.Status" />
        @if (job.MatchScore.HasValue)
        {
            <RadzenBadge BadgeStyle="BadgeStyle.Info">Match: @job.MatchScore%</RadzenBadge>
        }
        <RadzenBadge BadgeStyle="BadgeStyle.Secondary">@job.Platform</RadzenBadge>
    </div>

    <div class="detail-grid">
        <RadzenFieldset Text="Details">
            <div class="fieldset-grid">
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Job Type:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@job.JobType</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Posted:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@job.PostedDate.ToShortDateString()</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Easy Apply:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@(job.EasyApply ? "Yes" : "No")</RadzenText>
                @if (!string.IsNullOrEmpty(job.Url))
                {
                    <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">URL:</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2"><a href="@job.Url" target="_blank" rel="noopener">Open</a></RadzenText>
                }
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Profile:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@job.ProfileId</RadzenText>
            </div>
        </RadzenFieldset>

        <RadzenFieldset Text="Match Info">
            <div class="fieldset-grid">
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Score:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@(job.MatchScore?.ToString() ?? "N/A")</RadzenText>
                @if (job.Skills.Count > 0)
                {
                    <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Skills:</RadzenText>
                    <div class="skills-wrapper">
                        @foreach (var skill in job.Skills)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Light">@skill</RadzenBadge>
                        }
                    </div>
                }
            </div>
        </RadzenFieldset>
    </div>

    @if (!string.IsNullOrEmpty(job.Summary))
    {
        <RadzenFieldset Text="Summary" class="fieldset-section">
            <RadzenText TextStyle="TextStyle.Body2" class="text-pre-wrap">@job.Summary</RadzenText>
        </RadzenFieldset>
    }

    <RadzenFieldset Text="Description" class="fieldset-section">
        <RadzenText TextStyle="TextStyle.Body2" class="description-text">@job.Description</RadzenText>
    </RadzenFieldset>

    @if (!string.IsNullOrEmpty(job.MatchReasoning))
    {
        <RadzenFieldset Text="Match Reasoning" class="fieldset-section">
            <RadzenText TextStyle="TextStyle.Body2">@job.MatchReasoning</RadzenText>
        </RadzenFieldset>
    }

    @if (job.RedFlags.Count > 0)
    {
        <RadzenFieldset Text="Red Flags" class="fieldset-section">
            @foreach (var flag in job.RedFlags)
            {
                <RadzenText TextStyle="TextStyle.Body2" class="red-flag-text">• @flag</RadzenText>
            }
        </RadzenFieldset>
    }

    @if (job.Highlights.Count > 0)
    {
        <RadzenFieldset Text="Highlights" class="fieldset-section">
            @foreach (var highlight in job.Highlights)
            {
                <RadzenText TextStyle="TextStyle.Body2" class="highlight-text">• @highlight</RadzenText>
            }
        </RadzenFieldset>
    }

    <RadzenFieldset Text="Application" class="fieldset-section">
        <div class="fieldset-grid">
            @if (!string.IsNullOrEmpty(job.ResumeUsed))
            {
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Resume:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@job.ResumeUsed</RadzenText>
            }
            @if (!string.IsNullOrEmpty(job.CoverLetterUsed))
            {
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Cover Letter:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@job.CoverLetterUsed</RadzenText>
            }
            @if (!string.IsNullOrEmpty(job.UserNotes))
            {
                <RadzenText TextStyle="TextStyle.Body2" class="fieldset-label">Notes:</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="text-pre-wrap">@job.UserNotes</RadzenText>
            }
        </div>
    </RadzenFieldset>

    <div class="action-buttons">
        @if (job.Status == "New")
        {
            <RadzenButton Text="Approve" ButtonStyle="ButtonStyle.Success" Click="@ApproveJob" />
            <RadzenButton Text="Reject" ButtonStyle="ButtonStyle.Warning" Click="@RejectJob" />
        }
        @if (job.Status == "Approved")
        {
            <RadzenButton Text="Apply Now" ButtonStyle="ButtonStyle.Primary" Click="@ApplyToJob" />
        }
        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="@DeleteJob" />
    </div>
}
