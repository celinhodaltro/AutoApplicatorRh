@page "/"
@using Radzen
@using Radzen.Blazor

<div class="dashboard-header">
    <RadzenText TextStyle="TextStyle.H3" class="kpi-value">Dashboard</RadzenText>
    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary); margin-top: 4px;">
        Overview of your job application automation
    </RadzenText>
</div>

@if (_loading)
{
    <LoadingState />
}
else
{
    <div class="kpi-grid">
        <div class="kpi-card purple">
            <div class="kpi-header">
                <RadzenText TextStyle="TextStyle.Body2" class="kpi-label">Total Profiles</RadzenText>
                <RadzenIcon Icon="account_circle" style="font-size: 24px;" />
            </div>
            <RadzenText TextStyle="TextStyle.H2" class="kpi-value">@_totalProfiles</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="kpi-sub">@_activeProfiles active</RadzenText>
        </div>
        <div class="kpi-card pink">
            <div class="kpi-header">
                <RadzenText TextStyle="TextStyle.Body2" class="kpi-label">Total Jobs</RadzenText>
                <RadzenIcon Icon="work" style="font-size: 24px;" />
            </div>
            <RadzenText TextStyle="TextStyle.H2" class="kpi-value">@_totalJobs</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="kpi-sub">@_pendingReview pending review</RadzenText>
        </div>
        <div class="kpi-card blue">
            <div class="kpi-header">
                <RadzenText TextStyle="TextStyle.Body2" class="kpi-label">Applied</RadzenText>
                <RadzenIcon Icon="check_circle" style="font-size: 24px;" />
            </div>
            <RadzenText TextStyle="TextStyle.H2" class="kpi-value">@_appliedJobs</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="kpi-sub">@_approvedJobs approved to apply</RadzenText>
        </div>
        <div class="kpi-card green">
            <div class="kpi-header">
                <RadzenText TextStyle="TextStyle.Body2" class="kpi-label">Questions</RadzenText>
                <RadzenIcon Icon="help" style="font-size: 24px;" />
            </div>
            <RadzenText TextStyle="TextStyle.H2" class="kpi-value">@_totalQuestions</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="kpi-sub">@_unansweredQuestions unanswered</RadzenText>
        </div>
    </div>

    <div class="charts-row">
        <div class="chart-card">
            <RadzenText TextStyle="TextStyle.H6" class="chart-title"><RadzenIcon Icon="bar_chart" /> Jobs by Status</RadzenText>
            <div class="pipeline-container">
                <div class="pipeline">
                    @foreach (var item in _pipelineItems)
                    {
                        <div class="pipeline-card" style="background-color: @item.Color;">
                            <div class="pipeline-card-name">@item.Name</div>
                            <div class="pipeline-card-count">@item.Count</div>
                        </div>
                        @if (item != _pipelineItems.Last())
                        {
                            <div class="pipeline-arrow">→</div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="chart-card">
            <RadzenText TextStyle="TextStyle.H6" class="chart-title"><RadzenIcon Icon="track_changes" /> Jobs by Platform</RadzenText>
            <RadzenChart Style="height: 280px;">
                <RadzenPieSeries Data="@_jobsByPlatform" CategoryProperty="Category" ValueProperty="Value" />
                <RadzenLegend Position="LegendPosition.Right" />
            </RadzenChart>
        </div>
    </div>

    <div class="charts-row">
        <div class="chart-card">
            <RadzenText TextStyle="TextStyle.H6" class="chart-title"><RadzenIcon Icon="edit_note" /> Questions answered vs unanswered</RadzenText>
            <RadzenChart Style="height: 260px;">
                <RadzenPieSeries Data="@_questionsStatus" CategoryProperty="Category" ValueProperty="Value" />
                <RadzenLegend Position="LegendPosition.Right" />
            </RadzenChart>
        </div>
        <div class="actions-card">
            <RadzenText TextStyle="TextStyle.H6" class="chart-title"><RadzenIcon Icon="flash_on" /> Quick Actions</RadzenText>
            <div class="actions-list">
                <RadzenButton ButtonStyle="ButtonStyle.Primary" Style="width: 100%; justify-content: flex-start;" Click="@(() => Navigation.NavigateTo("/jobs"))">
                    <span class="action-btn-content"><RadzenIcon Icon="search" /> View Pending Jobs</span>
                </RadzenButton>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Style="width: 100%; justify-content: flex-start;" Click="@(() => Navigation.NavigateTo("/profiles"))">
                    <span class="action-btn-content"><RadzenIcon Icon="account_circle" /> Manage Profiles</span>
                </RadzenButton>
                <RadzenButton ButtonStyle="ButtonStyle.Info" Style="width: 100%; justify-content: flex-start;" Click="@(() => Navigation.NavigateTo("/questions"))">
                    <span class="action-btn-content"><RadzenIcon Icon="help" /> Answer Questions (@_unansweredQuestions unanswered)</span>
                </RadzenButton>
                <RadzenButton ButtonStyle="ButtonStyle.Base" Style="width: 100%; justify-content: flex-start;" Click="@(() => Navigation.NavigateTo("/settings"))">
                    <span class="action-btn-content"><RadzenIcon Icon="settings" /> Configure Settings</span>
                </RadzenButton>
            </div>
        </div>
    </div>

    <div class="recent-card">
        <div class="recent-header">
            <RadzenText TextStyle="TextStyle.H6" class="chart-title"><RadzenIcon Icon="format_list_bulleted" /> Recent Jobs</RadzenText>
            <RadzenButton Text="View All" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Base" Click="@(() => Navigation.NavigateTo("/jobs"))" />
        </div>

        @if (_recentJobs.Count == 0)
        {
            <EmptyState Message="No jobs collected yet. Create a profile to start searching." />
        }
        else
        {
            <div style="overflow-x: auto;">
                <table class="job-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Company</th>
                            <th>Platform</th>
                            <th>Status</th>
                            <th>Match</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in _recentJobs)
                        {
                            <tr>
                                <td><a href="/jobs/@job.Id" class="job-link">@job.Title</a></td>
                                <td>@job.Company</td>
                                <td><RadzenBadge BadgeStyle="BadgeStyle.Light">@job.Platform</RadzenBadge></td>
                                <td><StatusBadge Status="job.Status" /></td>
                                <td>
                                    @if (job.MatchScore.HasValue)
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Info">@job.MatchScore%</RadzenBadge>
                                    }
                                    else
                                    {
                                        <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-tertiary);">—</RadzenText>
                                    }
                                </td>
                                <td><RadzenButton Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Secondary" Click="@(() => Navigation.NavigateTo($"/jobs/{job.Id}"))">View</RadzenButton></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
