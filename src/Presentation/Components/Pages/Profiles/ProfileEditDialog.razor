@* ProfileEditDialog.razor *@
<div style="display:flex; flex-direction:column; gap:16px; min-width:500px;">

    @* Basic Information Section *@
    <div style="background:#fafbfc; border-radius:10px; padding:16px;">
        <RadzenText TextStyle="TextStyle.H6" style="font-weight:600; margin-bottom:12px; display:flex; align-items:center; gap:6px;">
            📋 Basic Information
        </RadzenText>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
            <!-- Name -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Profile Name</RadzenText>
                <RadzenTextBox @bind-Value="@_editingProfile.Name" Placeholder="e.g. Backend Developer" style="width:100%;" />
            </div>
            <!-- Platform -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Platform</RadzenText>
                <RadzenDropDown @bind-Value="@_formPlatform" Data="@_platformOptions" TextProperty="Text" ValueProperty="Value" Placeholder="Select platform" style="width:100%;" />
            </div>
        </div>
    </div>

    @* Search Criteria Section *@
    <div style="background:#fafbfc; border-radius:10px; padding:16px;">
        <RadzenText TextStyle="TextStyle.H6" style="font-weight:600; margin-bottom:12px; display:flex; align-items:center; gap:6px;">
            🔍 Search Criteria
        </RadzenText>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
            <!-- Keywords -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Keywords</RadzenText>
                <RadzenTextBox @bind-Value="@_formKeywords" Placeholder="e.g. .NET, React, Azure" style="width:100%;" />
            </div>
            <!-- Location -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Location</RadzenText>
                <RadzenTextBox @bind-Value="@_formLocation" Placeholder="e.g. Remote, São Paulo" style="width:100%;" />
            </div>
            <!-- Date Posted -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Date Posted</RadzenText>
                <RadzenDropDown @bind-Value="@_formDatePosted" Data="@_datePostedOptions" TextProperty="Text" ValueProperty="Value" Placeholder="Any" style="width:100%;" />
            </div>
            <!-- Salary Min -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Salary Min</RadzenText>
                <RadzenNumeric @bind-Value="@_editingProfile.SalaryMin" Min="0" style="width:100%;" />
            </div>
            <!-- Experience Level -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Experience Level</RadzenText>
                <RadzenTextBox @bind-Value="@_formExperienceLevel" Placeholder="e.g. Junior, Senior" style="width:100%;" />
            </div>
            <!-- Job Types -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Job Types</RadzenText>
                <RadzenTextBox @bind-Value="@_formJobTypes" Placeholder="e.g. Full-time, Contract" style="width:100%;" />
            </div>
            <!-- Exclude Terms -->
            <div>
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight:500; margin-bottom:4px;">Exclude Terms</RadzenText>
                <RadzenTextBox @bind-Value="@_formExcludeTerms" Placeholder="e.g. Java, PHP" style="width:100%;" />
            </div>
        </div>
    </div>

    @* Filters Section *@
    <div style="background:#fafbfc; border-radius:10px; padding:16px;">
        <RadzenText TextStyle="TextStyle.H6" style="font-weight:600; margin-bottom:12px; display:flex; align-items:center; gap:6px;">
            ⚙️ Filters
        </RadzenText>
        <div style="display:flex; flex-direction:column; gap:8px;">
            <div style="display:flex; align-items:center; gap:8px; padding:8px 12px; background:#f8f9ff; border-radius:6px;">
                <RadzenSwitch @bind-Value="@_editingProfile.EasyApplyOnly" />
                <div>
                    <div style="font-size:13px; font-weight:500;">Easy Apply Only</div>
                    <div style="font-size:11px; color:#888;">Skip jobs that don't offer Easy Apply</div>
                </div>
            </div>
            <div style="display:flex; align-items:center; gap:8px; padding:8px 12px; background:#f8f9ff; border-radius:6px;">
                <RadzenSwitch @bind-Value="@_editingProfile.RemoteOnly" />
                <div>
                    <div style="font-size:13px; font-weight:500;">Remote Only</div>
                    <div style="font-size:11px; color:#888;">Show only remote/work-from-home positions</div>
                </div>
            </div>
        </div>
    </div>

    @* Actions *@
    <div style="display:flex; gap:8px; justify-content:flex-end; padding-top:8px; border-top:1px solid #eee;">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Base" Click="@Cancel" />
        <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Click="@Save" />
    </div>
</div>
