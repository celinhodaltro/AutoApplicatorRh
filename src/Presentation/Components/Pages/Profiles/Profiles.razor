@page "/profiles"
@using Radzen
@using Radzen.Blazor
@using MediatR
@using AutoApplicator.Application.DTOs
@using AutoApplicator.Application.Queries.Profiles
@using AutoApplicator.Application.Commands.Profiles
@using AutoApplicator.Domain.Enums
@using AutoApplicator.Domain.Entities


<RadzenText TextStyle="TextStyle.H4" class="page-title">Search Profiles</RadzenText>

<div class="toolbar">
    <RadzenButton Text="New Profile" ButtonStyle="ButtonStyle.Primary" Click="@OpenNewProfileForm" />
</div>

<div class="table-wrapper">
    <table class="profiles-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Platform</th>
                <th>Keywords</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var profile in ViewModel.Profiles)
            {
                <tr>
                    <td>@profile.Name</td>
                    <td>@profile.Platform</td>
                    <td>@string.Join(", ", profile.Keywords.Take(3))@(profile.Keywords.Count > 3 ? "..." : "")</td>
                    <td>
                        <RadzenSwitch Value="@profile.Enabled" Change="@((bool val) => ToggleProfileEnabled(profile, val))" />
                    </td>
                    <td class="actions-cell">
                        <RadzenButton Text="Edit" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="@(() => OpenEditProfileForm(profile))" />
                        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => ConfirmDeleteProfile(profile))" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
