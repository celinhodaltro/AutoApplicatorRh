@page "/settings"
@using Radzen
@using Radzen.Blazor

<RadzenText TextStyle="TextStyle.H4" style="margin-bottom: 24px;">Settings</RadzenText>

<RadzenTabs>
    <RadzenTabsItem Text="API Keys">
        <div style="max-width: 500px;">
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">LinkedIn API Key</RadzenText>
                <RadzenTextBox @bind-Value="@_linkedInKey" Placeholder="Enter LinkedIn API key" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Indeed API Key</RadzenText>
                <RadzenTextBox @bind-Value="@_indeedKey" Placeholder="Enter Indeed API key" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Gupy API Key</RadzenText>
                <RadzenTextBox @bind-Value="@_gupyKey" Placeholder="Enter Gupy API key" style="width: 100%;" />
            </div>
            <RadzenButton Text="Save Keys" ButtonStyle="ButtonStyle.Primary" Click="@SaveApiKeys" />
        </div>
    </RadzenTabsItem>
    <RadzenTabsItem Text="Automation">
        <div style="max-width: 500px;">
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Delay between actions (ms)</RadzenText>
                <RadzenNumeric @bind-Value="@_actionDelay" Min="100" Max="30000" Step="100" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Cooldown between profiles (s)</RadzenText>
                <RadzenNumeric @bind-Value="@_profileCooldown" Min="0" Max="3600" Step="10" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Max applications per session</RadzenText>
                <RadzenNumeric @bind-Value="@_maxApplications" Min="1" Max="500" Step="1" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenCheckBox @bind-Value="@_headlessMode" Caption="Run browser in headless mode" />
            </div>
            <RadzenButton Text="Save Settings" ButtonStyle="ButtonStyle.Primary" Click="@SaveAutomationSettings" />
        </div>
    </RadzenTabsItem>
    <RadzenTabsItem Text="Profile">
        <div style="max-width: 500px;">
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Name</RadzenText>
                <RadzenTextBox @bind-Value="@_profile.Name" Placeholder="Your name" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Skills (comma separated)</RadzenText>
                <RadzenTextBox @bind-Value="@_skillsText" Placeholder="e.g. C#, .NET, SQL, Azure" style="width: 100%;" />
            </div>
            <div style="margin-bottom: 16px;">
                <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 500; margin-bottom: 4px;">Experience (one per line)</RadzenText>
                <RadzenTextArea @bind-Value="@_experienceText" Rows="4" Placeholder="e.g. 5 years Senior Developer at Company X" style="width: 100%;" />
            </div>
            <RadzenButton Text="Save Profile" ButtonStyle="ButtonStyle.Primary" Click="@SaveUserProfile" />
        </div>
    </RadzenTabsItem>
    <RadzenTabsItem Text="Logs">
        <div style="background: #1e1e1e; color: #d4d4d4; padding: 16px; border-radius: 4px; font-family: monospace; font-size: 0.8rem; max-height: 500px; overflow-y: auto;">
            @if (_logs.Count == 0)
            {
                <RadzenText TextStyle="TextStyle.Body2" style="color: #999;">No log entries yet.</RadzenText>
            }
            @foreach (var log in _logs)
            {
                <div>@log</div>
            }
        </div>
    </RadzenTabsItem>
</RadzenTabs>

@code {
    private string _linkedInKey = "";
    private string _indeedKey = "";
    private string _gupyKey = "";
    private int _actionDelay = 1000;
    private int _profileCooldown = 30;
    private int _maxApplications = 100;
    private bool _headlessMode = true;
    private UserProfile _profile = new() { Name = "" };
    private string _skillsText = "";
    private string _experienceText = "";
    private List<string> _logs = [];

    protected override async Task OnInitializedAsync()
    {
        _logs.Add($"[{DateTime.Now:T}] AutoApplicator initialized");
        _logs.Add($"[{DateTime.Now:T}] Ready to process profiles");
    }

    private Task SaveApiKeys()
    {
        _logs.Add($"[{DateTime.Now:T}] API keys saved (simulated)");
        return Task.CompletedTask;
    }

    private Task SaveAutomationSettings()
    {
        _logs.Add($"[{DateTime.Now:T}] Automation settings saved (delay={_actionDelay}ms, cooldown={_profileCooldown}s, max={_maxApplications})");
        return Task.CompletedTask;
    }

    private Task SaveUserProfile()
    {
        _profile.Skills = _skillsText
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        _profile.Experience = _experienceText
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        _logs.Add($"[{DateTime.Now:T}] User profile saved (simulated)");
        return Task.CompletedTask;
    }
}
