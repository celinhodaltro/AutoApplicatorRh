@page "/questions"
@using Radzen
@using Radzen.Blazor
@using AutoApplicator.Application.DTOs
@using AutoApplicator.Application.Interfaces
@inject QuestionListViewModel ViewModel
@inject INotificationService NotificationService

<div class="questions-page">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <RadzenText TextStyle="TextStyle.H4" class="page-title">
                Questions
            </RadzenText>

            <RadzenText TextStyle="TextStyle.Body2" class="page-subtitle">
                Manage and answer collected application questions
            </RadzenText>
        </div>

        <div class="header-actions">
            <RadzenButton Text="Save All"
                          Icon="save"
                          Size="ButtonSize.Small"
                          ButtonStyle="ButtonStyle.Primary"
                          Disabled="@(_modifiedQuestionIds.Count == 0)"
                          Click="@SaveAllAnswers" />
        </div>
    </div>

    <!-- UNANSWERED SECTION -->
    <div class="section @(!ViewModel.Unanswered.Any() ? "section--empty" : "")">
        <div class="section-header section-header--unanswered">
            <span class="section-title">❓ Unanswered (@ViewModel.Unanswered.Count)</span>
            @if (!ViewModel.Unanswered.Any())
            {
                <span class="section-all-answered">All answered ✨</span>
            }
        </div>

        <div class="questions-stack">
            @foreach (var question in ViewModel.Unanswered)
            {
                <div class="question-item unanswered">

                    <!-- TITLE -->
                    <div class="question-top">
                        <RadzenText TextStyle="TextStyle.Body1" class="question-title">
                            @question.QuestionText
                        </RadzenText>
                    </div>

                    <!-- TAGS -->
                    <div class="question-tags">
                        @if (!string.IsNullOrEmpty(question.Platform))
                        {
                            <RadzenBadge Text="@question.Platform"
                                         Shade="Shade.Light"
                                         Variant="Variant.Flat"
                                         class="platform-badge" />
                        }

                        <RadzenBadge Text="@GetTypeLabel(question.FieldType)"
                                     Shade="Shade.Light"
                                     Variant="Variant.Flat"
                                     class="type-badge" />
                    </div>

                    <!-- ANSWER INPUT -->
                    <div class="question-body">
                        @switch (question.FieldType)
                        {
                            case "Select":
                            case "Radio":

                                <RadzenDropDown @bind-Value="@_answers[question.Id]"
                                                Change="@(args => MarkModified(question.Id))"
                                                Data="@GetDropdownOptions(question.Options)"
                                                TextProperty="Text"
                                                ValueProperty="Value"
                                                Placeholder="Select answer"
                                                Size="InputSize.Small"
                                                Style="width:100%;" />
                                break;

                            case "Textarea":

                                <RadzenTextArea @bind-Value="@_answers[question.Id]"
                                                Change="@(args => MarkModified(question.Id))"
                                                Rows="2"
                                                Placeholder="Type your answer..."
                                                Size="InputSize.Small"
                                                Style="width:100%;" />
                                break;

                            case "Checkbox":

                                <RadzenCheckBox @bind-Value="@_checkboxAnswers[question.Id]"
                                                Change="@(args => MarkModified(question.Id))"
                                                TValue="bool" />
                                break;

                            default:

                                <RadzenTextBox @bind-Value="@_answers[question.Id]"
                                               Change="@(args => MarkModified(question.Id))"
                                               Placeholder="Type your answer..."
                                               Size="InputSize.Small"
                                               Style="width:100%;" />
                                break;
                        }
                    </div>

                    <!-- FOOTER -->
                    <div class="question-footer">
                        <div class="card-actions">
                            <RadzenButton Text="Save"
                                          Icon="save"
                                          Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Success"
                                          Disabled="@(question.FieldType != "Checkbox" && string.IsNullOrEmpty(_answers[question.Id]))"
                                          Click="@(() => SaveSingleAnswer(question.Id))" />

                            <RadzenButton Text="Delete"
                                          Icon="delete"
                                          Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Variant="Variant.Flat"
                                          Click="@(() => DeleteQuestion(question.Id))" />
                        </div>
                    </div>

                </div>
            }
        </div>
    </div>

    <!-- ANSWERED SECTION -->
    <div class="section @(!ViewModel.Answered.Any() ? "section--empty" : "")">
        <div class="section-header section-header--answered @(showAnswered ? "is-expanded" : "")"
             @onclick="ToggleAnsweredSection"
             role="button"
             tabindex="0"
             @onkeydown="HandleAnsweredSectionKeyDown">

            <span class="section-title">✅ Answered (@ViewModel.Answered.Count)</span>
            <span class="section-toggle">@(showAnswered ? "▲" : "▼")</span>
        </div>

        <div class="questions-stack collapse-section @(showAnswered ? "is-visible" : "")">
            @foreach (var question in ViewModel.Answered)
            {
                <div class="question-item answered @(_expandedCardIds.Contains(question.Id) ? "expanded" : "collapsed")">

                    @if (_expandedCardIds.Contains(question.Id))
                    {
                        @* ─── EXPANDED ─── *@

                        <!-- TITLE -->
                        <div class="question-top">
                            <RadzenText TextStyle="TextStyle.Body1" class="question-title">
                                @question.QuestionText
                            </RadzenText>
                        </div>

                        <!-- TAGS -->
                        <div class="question-tags">
                            @if (!string.IsNullOrEmpty(question.Platform))
                            {
                                <RadzenBadge Text="@question.Platform"
                                             Shade="Shade.Light"
                                             Variant="Variant.Flat"
                                             class="platform-badge" />
                            }

                            <RadzenBadge Text="@GetTypeLabel(question.FieldType)"
                                         Shade="Shade.Light"
                                         Variant="Variant.Flat"
                                         class="type-badge" />
                        </div>

                        <!-- ANSWER INPUT -->
                        <div class="question-body">
                            @switch (question.FieldType)
                            {
                                case "Select":
                                case "Radio":

                                    <RadzenDropDown @bind-Value="@_answers[question.Id]"
                                                    Change="@(args => MarkModified(question.Id))"
                                                    Data="@GetDropdownOptions(question.Options)"
                                                    TextProperty="Text"
                                                    ValueProperty="Value"
                                                    Placeholder="Select answer"
                                                    Size="InputSize.Small"
                                                    Style="width:100%;" />
                                    break;

                                case "Textarea":

                                    <RadzenTextArea @bind-Value="@_answers[question.Id]"
                                                    Change="@(args => MarkModified(question.Id))"
                                                    Rows="2"
                                                    Placeholder="Type your answer..."
                                                    Size="InputSize.Small"
                                                    Style="width:100%;" />
                                    break;

                                case "Checkbox":

                                    <RadzenCheckBox @bind-Value="@_checkboxAnswers[question.Id]"
                                                    Change="@(args => MarkModified(question.Id))"
                                                    TValue="bool" />
                                    break;

                                default:

                                    <RadzenTextBox @bind-Value="@_answers[question.Id]"
                                                   Change="@(args => MarkModified(question.Id))"
                                                   Placeholder="Type your answer..."
                                                   Size="InputSize.Small"
                                                   Style="width:100%;" />
                                    break;
                            }
                        </div>

                        <!-- FOOTER -->
                        <div class="question-footer">
                            <div class="card-actions">
                                <RadzenButton Text="Save"
                                              Icon="save"
                                              Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Success"
                                              Disabled="@(question.FieldType != "Checkbox" && string.IsNullOrEmpty(_answers[question.Id]))"
                                              Click="@(() => SaveSingleAnswer(question.Id))" />

                                <RadzenButton Text="▲ Hide"
                                              Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Light"
                                              Variant="Variant.Flat"
                                              Click="@(() => ToggleCardExpand(question.Id))" />

                                <RadzenButton Text="Delete"
                                              Icon="delete"
                                              Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Variant="Variant.Flat"
                                              Click="@(() => DeleteQuestion(question.Id))" />
                            </div>
                        </div>
                    }
                    else
                    {
                        @* ─── COLLAPSED ─── *@

                        <div class="collapsed-row" @onclick="() => ToggleCardExpand(question.Id)">
                            <div class="collapsed-info">
                                <span class="collapsed-question">@question.QuestionText</span>
                                <span class="collapsed-answer">
                                    Answer: "@TruncateAnswer(question.Answer)"
                                </span>
                            </div>
                            <div class="collapsed-actions">
                                <RadzenBadge Text="@GetTypeLabel(question.FieldType)"
                                             Shade="Shade.Light"
                                             Variant="Variant.Flat"
                                             class="type-badge" />
                                <span class="expand-btn">▶ Show</span>
                            </div>
                        </div>
                    }

                </div>
            }
        </div>
    </div>

    @if (ViewModel.Questions.Count == 0)
    {
        <RadzenCard class="empty-card">
            <RadzenText TextStyle="TextStyle.Body1">
                No questions found.
            </RadzenText>
        </RadzenCard>
    }

</div>

@code {
    private Dictionary<Guid, string> _answers = [];
    private Dictionary<Guid, bool> _checkboxAnswers = [];
    private HashSet<Guid> _modifiedQuestionIds = [];

    private bool showAnswered;
    private HashSet<Guid> _expandedCardIds = [];

    // ──────────────────────────────────────────────
    //  Lifecycle
    // ──────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadQuestionsAsync();
        InitializeAnswerDictionaries();
    }

    // ──────────────────────────────────────────────
    //  Data
    // ──────────────────────────────────────────────

    private void InitializeAnswerDictionaries()
    {
        _answers = ViewModel.Questions.ToDictionary(q => q.Id, q => q.Answer);
        _checkboxAnswers = ViewModel.Questions.ToDictionary(q => q.Id, q => !string.IsNullOrEmpty(q.Answer));
        _modifiedQuestionIds.Clear();
    }

    // ──────────────────────────────────────────────
    //  Section / Card toggles
    // ──────────────────────────────────────────────

    private void ToggleAnsweredSection()
    {
        showAnswered = !showAnswered;

        if (showAnswered)
        {
            // Expand all answered cards when section opens
            _expandedCardIds = ViewModel.Answered.Select(q => q.Id).ToHashSet();
        }
        else
        {
            // Collapse all answered cards when section closes
            _expandedCardIds.Clear();
        }
    }

    private void HandleAnsweredSectionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
        {
            ToggleAnsweredSection();
        }
    }

    private void ToggleCardExpand(Guid questionId)
    {
        if (_expandedCardIds.Contains(questionId))
            _expandedCardIds.Remove(questionId);
        else
            _expandedCardIds.Add(questionId);
    }

    // ──────────────────────────────────────────────
    //  Answer tracking
    // ──────────────────────────────────────────────

    private void MarkModified(Guid questionId)
    {
        _modifiedQuestionIds.Add(questionId);
    }

    private async Task SaveSingleAnswer(Guid questionId)
    {
        try
        {
            var question = ViewModel.Questions.FirstOrDefault(q => q.Id == questionId);
            if (question is null) return;

            var answer = question.FieldType == "Checkbox"
                ? (_checkboxAnswers.GetValueOrDefault(questionId) ? "Yes" : "")
                : (_answers.GetValueOrDefault(questionId) ?? "");

            if (question.FieldType != "Checkbox" && string.IsNullOrEmpty(answer))
            {
                NotificationService.Add(
                    NotificationType.Warning,
                    "Warning",
                    "Please provide an answer before saving.");
                return;
            }

            await ViewModel.SaveAnswerAsync(questionId, answer);
            _modifiedQuestionIds.Remove(questionId);
            InitializeAnswerDictionaries();

            NotificationService.Add(
                NotificationType.Success,
                "Saved",
                "Answer saved successfully.");
        }
        catch (Exception ex)
        {
            NotificationService.Add(
                NotificationType.Error,
                "Error",
                $"Failed to save answer: {ex.Message}");
        }
    }

    private async Task SaveAllAnswers()
    {
        var errors = new List<string>();

        foreach (var questionId in _modifiedQuestionIds)
        {
            try
            {
                var question = ViewModel.Questions.FirstOrDefault(q => q.Id == questionId);
                if (question is null) continue;

                var answer = question.FieldType == "Checkbox"
                    ? (_checkboxAnswers.GetValueOrDefault(questionId) ? "Yes" : "")
                    : (_answers.GetValueOrDefault(questionId) ?? "");

                await ViewModel.SaveAnswerAsync(questionId, answer);
            }
            catch (Exception ex)
            {
                errors.Add($"Question {questionId}: {ex.Message}");
            }
        }

        _modifiedQuestionIds.Clear();

        if (errors.Count == 0)
        {
            NotificationService.Add(
                NotificationType.Success,
                "Saved",
                "All answers saved successfully.");
        }
        else
        {
            NotificationService.Add(
                NotificationType.Warning,
                "Partial Save",
                $"{errors.Count} question(s) failed to save.");
        }

        InitializeAnswerDictionaries();
    }

    private async Task DeleteQuestion(Guid questionId)
    {
        try
        {
            await ViewModel.DeleteQuestionAsync(questionId);
            _modifiedQuestionIds.Remove(questionId);
            InitializeAnswerDictionaries();

            NotificationService.Add(
                NotificationType.Success,
                "Deleted",
                "Question deleted successfully.");
        }
        catch (Exception ex)
        {
            NotificationService.Add(
                NotificationType.Error,
                "Error",
                $"Failed to delete question: {ex.Message}");
        }
    }

    // ──────────────────────────────────────────────
    //  Helpers
    // ──────────────────────────────────────────────

    private static string GetTypeLabel(string fieldType) => fieldType switch
    {
        "Select" => "Select",
        "Radio" => "Radio",
        "Checkbox" => "Checkbox",
        "File" => "File",
        _ => "Input"
    };

    private static string TruncateAnswer(string answer, int maxLength = 60)
    {
        if (string.IsNullOrEmpty(answer)) return "";
        return answer.Length > maxLength ? answer[..maxLength] + "…" : answer;
    }

    private List<OptionItem> GetDropdownOptions(List<string>? options)
    {
        return options?
            .Where(o => !string.IsNullOrWhiteSpace(o))
            .Select(o => new OptionItem { Text = o, Value = o })
            .ToList() ?? [];
    }

    private class OptionItem
    {
        public string Text { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
